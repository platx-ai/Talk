    "ModelScope（中国大陆）": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "ModelScope（中国大陆）"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "ModelScope (China Mainland)"
          }
        }
      }
    },
    "Talk 使用本地 AI 模型进行语音识别和文本润色，首次使用需下载约 3GB 模型文件。": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Talk 使用本地 AI 模型进行语音识别和文本润色，首次使用需下载约 3GB 模型文件。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Talk uses on-device AI models for speech recognition and text polishing. First-time use requires downloading ~3GB of model files."
          }
        }
      }
    },
    "Talk 已就绪！": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Talk 已就绪！"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Talk is ready!"
          }
        }
      }
    },
    "Talk 是 macOS 语音输入工具。按下快捷键说话，AI 自动识别、润色并输入到光标位置。全部在本地运行，无需联网。": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Talk 是 macOS 语音输入工具。按下快捷键说话，AI 自动识别、润色并输入到光标位置。全部在本地运行，无需联网。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Talk is a macOS voice input tool. Press the hotkey to speak, and AI will recognize, polish, and insert text at your cursor. Everything runs locally, no internet needed."
          }
        }
      }
    },
    "Talk 有新版本": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Talk 有新版本"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Talk Update Available"
          }
        }
      }
    },
    "Talk 需要以下权限才能完整工作": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Talk 需要以下权限才能完整工作"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Talk needs the following permissions to work fully"
          }
        }
      }
    },
    "Talk 需要录制你的语音，音频仅在本地处理。": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Talk 需要录制你的语音，音频仅在本地处理。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Talk needs to record your voice. Audio is processed locally only."
          }
        }
      }
    },
    "Talk 需要辅助功能权限来将文字自动粘贴到当前应用。": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Talk 需要辅助功能权限来将文字自动粘贴到当前应用。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Talk needs Accessibility to auto-paste text into apps."
          }
        }
      }
    },
    "Talk 需要输入监控权限来监听全局快捷键。": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Talk 需要输入监控权限来监听全局快捷键。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Talk needs Input Monitoring to listen for global hotkeys."
          }
        }
      }
    },
    "Talk 需要麦克风权限才能录音。\\n\\n如果没有弹出系统授权窗口，请手动前往：\\n系统设置 → 隐私与安全性 → 麦克风，为 Talk 开启权限。": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Talk 需要麦克风权限才能录音。\\n\\n如果没有弹出系统授权窗口，请手动前往：\\n系统设置 → 隐私与安全性 → 麦克风，为 Talk 开启权限。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Talk needs microphone permission to record.\n\nIf no system prompt appeared, go to:\nSystem Settings → Privacy & Security → Microphone, and enable Talk."
          }
        }
      }
    },
    "\\(settings.conversationHistoryRounds) 轮": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\\(settings.conversationHistoryRounds) 轮"
