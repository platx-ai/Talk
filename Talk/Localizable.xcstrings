    "Accessibility 权限未授予！已弹出授权请求。": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Accessibility 权限未授予！已弹出授权请求。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Accessibility permission not granted. Authorization requested."
          }
        }
      }
    },
    "Accessibility 权限未授予，CGEvent 无法发送到其他应用。": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Accessibility 权限未授予，CGEvent 无法发送到其他应用。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Accessibility permission not granted. CGEvent cannot be sent to other apps."
          }
        }
      }
    },
    "Cmd+C 复制（兼容性好）": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Cmd+C 复制（兼容性好）"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Cmd+C Copy (Better compatibility)"
          }
        }
      }
    },
    "HuggingFace（国际）": {
