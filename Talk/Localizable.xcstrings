    "全局快捷键依赖输入监控权限。若快捷键无反应，请在系统设置 → 隐私与安全性 → 输入监控中开启 Talk，并重启应用。": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "全局快捷键依赖输入监控权限。若快捷键无反应，请在系统设置 → 隐私与安全性 → 输入监控中开启 Talk，并重启应用。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Global hotkey requires Input Monitoring permission. If hotkey doesn't respond, enable Talk in System Settings → Privacy & Security → Input Monitoring, then restart."
          }
        }
      }
    },
